# ─── Supabase ───────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── WhatsApp Business Cloud API ────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=123456789
WHATSAPP_ACCESS_TOKEN=EAAxxxx
WHATSAPP_VERIFY_TOKEN=meu_token_secreto_aleatorio
WHATSAPP_APP_SECRET=xxxx  # usado para validar assinatura HMAC

# ─── Google Calendar (Service Account) ──────────────────────────
# JSON da service account em base64: base64 -i service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=eyJ0...
GOOGLE_CALENDAR_ID=cynthia@gmail.com

# ─── Resend (e-mail transacional) ────────────────────────────────
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=noreply@dracynthia.com.br

# ─── Upstash Redis (rate limiting) ──────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxx

# ─── Analytics ──────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=123456789

# ─── Agendamento online ──────────────────────────────────────────
NEXT_PUBLIC_CAL_LINK=https://cal.com/dra-cynthia/avaliacao

# ─── Admin ──────────────────────────────────────────────────────
ADMIN_SECRET_PATH=meu-caminho-secreto  # não usado atualmente — auth via Supabase

# ─── Cron (Vercel Cron Jobs) ─────────────────────────────────────
CRON_SECRET=chave-aleatoria-para-proteger-crons
